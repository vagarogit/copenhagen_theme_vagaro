  </a>
</div>

<script>
  (function () {
    var id = Math.random() < 0.5 ? 'paypro-banner-variant' : 'payprogo-banner-variant';
    var el = document.getElementById(id);
    if (el) {
      el.style.display = '';
    }
  })();
</script>
<header class="bg-white sticky top-0 z-50 shadow-sm">
  <div class="mx-auto">
    <!-- Top row with logo and auth buttons -->
    <div
      class="relative flex h-16 justify-center items-center border-b border-gray-100 mx-auto px-2 border w-full"
    >
      <!-- Logo -->
      <div
        class="absolute left-2 md:left-4 lg:left-8 flex shrink-0 items-center"
      >
        {{#link "help_center" class="flex items-center"}}
          <img
            src="{{asset 'logo.svg'}}"
            alt="{{t 'home_page' name=help_center.name}}"
            class="h-[28px] w-[108px]"
          />
        {{/link}}
      </div>

      <!-- Mobile Start Free Trial Button (centered) - Hidden, replaced by dynamic sticky banner -->
      <!-- The dynamic banner is initialized by mobile-cta-banner-bundle.js -->
      <div class="lg:hidden" aria-hidden="true"></div>

      <!-- Auth & Region -->
      <div class="absolute right-4 lg:right-8 flex items-center space-x-4">
        <button
          type="button"
          class="text-gray-600 hover:text-gray-900 lg:hidden hidden"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
            ></path>
          </svg>
        </button>

        <div class="hidden lg:flex items-center space-x-8">
          <div class="flex items-center mr-4">
            <img
              src="https://flagicons.lipis.dev/flags/4x3/us.svg"
              alt="US"
              class="w-5 h-auto mr-1"
            />
            <span class="text-sm font-bold">US</span>
          </div>

          {{! <a
            href="#"
            class="text-sm font-medium text-charcoal hover:text-gray-900 mr-4"
          >Log In</a> }}

          <a
            href="https://www.vagaro.com/signup-1?licence=1"
            class="flex items-center justify-center bg-primary hover:bg-charcoal hover:border-solid text-md text-white py-2 px-4 rounded-full w-auto md:w-[145px] h-[50px] text-base font-semibold"
          >
            Start Free Trial
          </a>
        </div>

        <!-- Mobile menu button -->
        <div class="flex items-center lg:hidden">
          <button
            type="button"
            class="menu-button-mobile relative inline-flex items-center justify-center rounded-md p-2 text-primary hover:bg-gray-100 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-indigo-500"
            aria-controls="mobile-navigation-root"
            aria-expanded="false"
            aria-label="{{t 'toggle_navigation'}}"
            onclick="if (window.toggleMobileNavigation) { window.toggleMobileNavigation(); }"
          >
            {{#if signed_in}}
              {{user_avatar class="size-8 rounded-full mr-2 user-avatar"}}
            {{/if}}
            <svg
              class="size-8"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
              />
            </svg>
          </button>
        </div>
      </div>
    </div>
    <div id="radix-navigation-root" class="flex justify-center w-full" data-navdata-url='{{asset "navdata.json"}}'></div>
  </div>

</header>