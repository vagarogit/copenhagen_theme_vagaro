          alt="PayPro promotional banner"
          class="block h-full w-auto max-w-none border-0 object-contain"
          width="128"
          height="110"
        />
      </div>
      <div
        class="flex flex-col justify-center gap-1 md:flex-row md:justify-start md:gap-0"
      >
