<a
  class="skip-navigation"
  tabindex="1"
  href="#main-content"
  onclick="
  // Fallback for skip navigation if main-content doesn't exist
  const target = document.getElementById('main-content');
  if (!target) {
    const fallbacks = ['.container', '.section', 'main', 'article'];
    for (const selector of fallbacks) {
      const fallback = document.querySelector(selector);
      if (fallback) {
        fallback.focus();
        fallback.scrollIntoView();
        return false;
      }
    }
  }
  return true;
"
>{{t "skip_navigation"}}</a>

<style>
  .payprogo-banner-link {
    background: linear-gradient(102.89deg, #CC4744 1.87%, #8055A3 49.85%, #5F6DB3 97.77%);
  }
  @media (min-width: 768px) {
    .payprogo-banner-link {
      background: linear-gradient(132.76deg, #CC4744 1.87%, #8055A3 33.52%, #5F6DB3 65.16%, #1D7F9C 96.81%);
    }
  }
</style>

<!-- A/B banner: 50% PayPro, 50% PayProGo. Both hidden by default; the inline script below reveals one before paint. -->
<div
