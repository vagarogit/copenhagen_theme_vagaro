    href="https://www.vagaro.com/pro/pos-hardware"
    class="mx-auto flex h-full w-full flex-none cursor-pointer flex-row items-center justify-center gap-6 border-none py-4 text-center text-base leading-8 transition-colors sm:border-none xl:border-none"
    id="paypro-banner"
    rel="noopener noreferrer"
    target="_blank"
    style="background: linear-gradient(90deg, #422929 0%, #CC4744 64.07%, #773838 100%);"
  >
    <div class="relative flex items-center">
      <div class="mx-auto mr-0 flex h-16 items-center justify-start">
        <img
