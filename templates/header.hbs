    id="payprogo-topbanner"
    rel="noopener noreferrer"
    target="_blank"
  >
    <div class="relative h-16 w-20 shrink-0">
      <img
        src="https://us-west-2.graphassets.com/AalLHDRueT6SDLkGLppQVz/cmp4hfrz4j93l07lo9e1ukncy"
        alt="Free card reader promotional banner"
        class="absolute inset-0 h-full w-full object-contain"
        width="80"
        height="64"
      />
    </div>
    <div
      class="flex min-w-0 flex-1 flex-col items-center justify-center gap-0.5 text-center text-white md:flex-none md:gap-1 md:whitespace-nowrap"
    >
      <p class="text-xs font-medium md:text-lg">
        FREE card reader when you sign up for Vagaro Merchant Services
      </p>
      <p class="text-[9px] whitespace-nowrap md:text-[10px]">
